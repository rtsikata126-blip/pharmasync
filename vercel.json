{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "outputDirectory": "dist/client",
  "framework": "vite",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/sw\\.js$",
      "dest": "/sw.js"
    },
    {
      "src": "/favicon\\.(ico|png|svg|webp)$",
      "dest": "/favicon.svg"
    },
    {
      "src": "/manifest\\.webmanifest$",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "/icon(-\\d+)?\\.(png|svg)$",
      "dest": "/icon$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
